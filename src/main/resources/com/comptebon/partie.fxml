<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!-- il faudra faire diviser les composants de la frame  -->

<VBox alignment="TOP_CENTER" spacing="15" xmlns:fx="http://javafx.com/fxml" fx:controller="com.comptebon.controller.PartieController" style="-fx-background-color: #E5E7EB;">

    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <HBox alignment="CENTER" style="-fx-background-color: white; -fx-border-color: #312E81; -fx-border-radius: 15; -fx-background-radius: 15; -fx-border-width: 2;" maxWidth="250">
        <Label text="Le Compte est Bon" style="-fx-font-weight: bold; -fx-text-fill: #312E81;"/>
    </HBox>

    <VBox alignment="CENTER">
        <Label text="Valeur cible :" style="-fx-text-fill: #4B5563;"/>
        <Label fx:id="cibleLabel" text="318" style="-fx-font-size: 50; -fx-font-weight: bold; -fx-text-fill: #1E1B4B;"/>
    </VBox>

    <HBox alignment="CENTER" spacing="10">
        <Label text="3" styleClass="plaque" style="-fx-background-color: white; -fx-border-color: #312E81; -fx-padding: 10 15; -fx-font-size: 18; -fx-font-weight: bold; -fx-border-radius: 5;"/>
        <Label text="8" style="-fx-background-color: white; -fx-border-color: #312E81; -fx-padding: 10 15; -fx-font-size: 18; -fx-font-weight: bold; -fx-border-radius: 5;"/>
        <Label text="14" style="-fx-background-color: white; -fx-border-color: #312E81; -fx-padding: 10 15; -fx-font-size: 18; -fx-font-weight: bold; -fx-border-radius: 5;"/>
        <Label text="75" style="-fx-background-color: white; -fx-border-color: #312E81; -fx-padding: 10 15; -fx-font-size: 18; -fx-font-weight: bold; -fx-border-radius: 5;"/>
    </HBox>

    <HBox alignment="CENTER" spacing="10">
        <Button text="+" onAction="#onAdditionner" style="-fx-background-color: #BE185D; -fx-text-fill: white; -fx-font-size: 20; -fx-pref-width: 50;"/>
        <Button text="-" onAction="#onSoustraire" style="-fx-background-color: #BE185D; -fx-text-fill: white; -fx-font-size: 20; -fx-pref-width: 50;"/>
        <Button text="×" onAction="#onMultiplier" style="-fx-background-color: #BE185D; -fx-text-fill: white; -fx-font-size: 20; -fx-pref-width: 50;"/>
    </HBox>

    <StackPane VBox.vgrow="ALWAYS">
        <TextArea fx:id="zoneCalcul" prefHeight="200" style="-fx-border-color: #312E81; -fx-border-width: 3; -fx-border-radius: 10; -fx-background-radius: 10;"/>
    </StackPane>

</VBox>