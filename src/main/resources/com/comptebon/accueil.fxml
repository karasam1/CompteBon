<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>

<StackPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #f2eefa;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.comptebon.controller.AccueilController">
   <children>
      <VBox alignment="CENTER" spacing="40.0">
         <children>
            <Label style="-fx-font-size: 40px; -fx-font-weight: bold; -fx-text-fill: #4a2c75;" text="Le Compte est Bon" />
            <Button mnemonicParsing="false" onAction="#allerVersParametres" style="-fx-background-color: #b52b57; -fx-text-fill: white; -fx-font-size: 20px; -fx-padding: 15 30; -fx-background-radius: 30; -fx-min-width: 300px;" text="Nouvelle Partie" />
            <Button mnemonicParsing="false" onAction="#chargerPartieAccueil" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 20px; -fx-padding: 15 30; -fx-background-radius: 30; -fx-min-width: 300px;" text="Charger une Partie" />
            <Button mnemonicParsing="false" onAction="#quitterApp" style="-fx-background-color: #666666; -fx-text-fill: white; -fx-font-size: 20px; -fx-padding: 15 30; -fx-background-radius: 30; -fx-min-width: 300px;" text="Fermer" />
         </children>
      </VBox>
   </children>
</StackPane>