<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<!-- 
    Vue de configuration du Compte Est Bon.
    Le style imite le rendu d'une carte sur fond gris avec un en-tête moderne. 
-->
<StackPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.comptebon.controller.ConfigController" style="-fx-background-color: #D1D5DB;" prefWidth="800" prefHeight="600">
    <VBox alignment="CENTER" spacing="20" maxWidth="600">
        
        <!-- Encart "Titre en cours" -->
        <Label text="Le Compte est Bon #392" style="-fx-background-color: white; -fx-background-radius: 20; -fx-font-weight: bold; -fx-font-size: 14; -fx-text-fill: #1E1B4B; -fx-padding: 5 15;" />
        
        <!-- Titre Principal -->
        <Label text="Configurer les paramètres" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #312E81;" />
        
        <!-- Conteneur pour superposer la carte et les petits boutons d'opérateurs au dessus -->
        <VBox alignment="TOP_CENTER">
            
            <!-- Boutons d'Opérations flottants au dessus de la bordure de la boîte  -->
            <HBox alignment="CENTER" spacing="10" style="-fx-translate-y: 15; -fx-view-order: -1;">
                <Button text="+" style="-fx-background-color: #BE185D; -fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold; -fx-background-radius: 8; -fx-min-width: 40; -fx-min-height: 40; -fx-cursor: hand;" />
                <Button text="-" style="-fx-background-color: #BE185D; -fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold; -fx-background-radius: 8; -fx-min-width: 40; -fx-min-height: 40; -fx-cursor: hand;" />
                <Button text="×" style="-fx-background-color: #BE185D; -fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold; -fx-background-radius: 8; -fx-min-width: 40; -fx-min-height: 40; -fx-cursor: hand;" />
                <Button text="÷" style="-fx-background-color: #BE185D; -fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold; -fx-background-radius: 8; -fx-min-width: 40; -fx-min-height: 40; -fx-cursor: hand;" />
            </HBox>
            
            <!-- Carte Centrale (Bordure bleue foncée, fond blanc) -->
            <VBox style="-fx-background-color: #F8FAFC; -fx-background-radius: 12; -fx-border-color: #312E81; -fx-border-radius: 12; -fx-border-width: 2;" spacing="20">
                <padding><Insets top="40" right="40" bottom="30" left="40" /></padding>
                
                <GridPane vgap="25" hgap="20" alignment="CENTER_LEFT">
                    <columnConstraints>
                        <ColumnConstraints minWidth="200" />
                        <ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>
                    
                    <!-- Ligne 1 : Nombre de plaques (avec Slider) -->
                    <Label text="Nombre de plaques :" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #1E1B4B; -fx-font-weight: bold; -fx-font-size: 14;" />
                    <HBox alignment="CENTER_LEFT" spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label text="6" style="-fx-text-fill: #6B7280; -fx-font-weight: bold;"/>
                        <Slider fx:id="sliderNbPlaques" min="6" max="10" value="6" blockIncrement="1" majorTickUnit="1" minorTickCount="0" snapToTicks="true" HBox.hgrow="ALWAYS" />
                        
                        <!-- La valeur du slider sera appliquée à ce textfield depuis le contrôleur java par la méthode initialize() -->
                        <TextField fx:id="txtNbPlaques" prefWidth="45" alignment="CENTER" editable="false" style="-fx-background-radius: 5; -fx-border-color: #D1D5DB; -fx-border-radius: 5; -fx-text-fill: #1E1B4B;" />
                    </HBox>

                    <!-- Ligne 2 : Valeur Cible Min -->
                    <Label text="Valeur cible - Minimum :" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #1E1B4B; -fx-font-weight: bold; -fx-font-size: 14;" />
                    <TextField fx:id="txtPlageCibleMin" text="100" GridPane.columnIndex="1" GridPane.rowIndex="1" style="-fx-background-radius: 5; -fx-border-color: #D1D5DB; -fx-border-radius: 5; -fx-text-fill: #1E1B4B;" />

                    <!-- Ligne 3 : Valeur Cible Max -->
                    <Label text="Valeur cible - Maximum :" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill: #1E1B4B; -fx-font-weight: bold; -fx-font-size: 14;" />
                    <TextField fx:id="txtPlageCibleMax" text="999" GridPane.columnIndex="1" GridPane.rowIndex="2" style="-fx-background-radius: 5; -fx-border-color: #D1D5DB; -fx-border-radius: 5; -fx-text-fill: #1E1B4B;" />

                    <!-- Ligne 4 : Mode de difficulté (Espace vide équivalent à l'image) -->
                    <Label text="Mode de difficulté :" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-text-fill: #1E1B4B; -fx-font-weight: bold; -fx-font-size: 14;" />
                    <!-- On peut placer ici une liste déroulante plus tard si besoin. -->

                    <!-- Ligne 5 : Chronomètre (Toggle Visuel) -->
                    <Label text="Chronomètre :" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-text-fill: #1E1B4B; -fx-font-weight: bold; -fx-font-size: 14;" />
                    <HBox alignment="CENTER_RIGHT" GridPane.columnIndex="1" GridPane.rowIndex="4">
                        <!-- Case à cocher agrandie simulant le design d'un bouton switch. -->
                        <CheckBox fx:id="chkChrono" selected="true" style="-fx-scale-x: 1.3; -fx-scale-y: 1.3; -fx-cursor: hand;" />
                    </HBox>
                </GridPane>

                <!-- Zone des actions au bas de la carte (Boutons validant le formulaire) -->
                <!-- Ces boutons appellent les méthodes onAnnuler et onLancerPartie définies dans le Controller Java -->
                <HBox alignment="CENTER" spacing="30" style="-fx-padding: 20 0 0 0;">
                    <Button text="Annuler" onAction="#onAnnuler" style="-fx-background-color: #BE185D; -fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold; -fx-background-radius: 30; -fx-padding: 10 40; -fx-cursor: hand; -fx-pref-width: 200;" />
                    <Button text="Lancer la partie" onAction="#onLancerPartie" style="-fx-background-color: #BE185D; -fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold; -fx-background-radius: 30; -fx-padding: 10 40; -fx-cursor: hand; -fx-pref-width: 200;" />
                </HBox>

            </VBox>
        </VBox>
    </VBox>
</StackPane>
